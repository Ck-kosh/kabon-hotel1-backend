# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-service-name.onrender.com

# Render PostgreSQL (copy Internal Database URL from Render)
DATABASE_URL=postgresql://user:password@host:5432/database
# Alternatively, provide all of these instead of DATABASE_URL:
# DB_HOST=host
# DB_NAME=database
# DB_USER=user
# DB_PASSWORD=password
# DB_PORT=5432

# Browser origins: comma-separated, no trailing slash
CORS_ALLOWED_ORIGINS=https://kabon-hotel1-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://kabon-hotel1-frontend.vercel.app

# Persistent media uploads (Cloudinary URL)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# SMTP email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.com
